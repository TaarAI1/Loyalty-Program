    {
      "name": "5. Configuration",
      "item": [
        {
          "name": "Loyalty Tiers",
          "item": [
            {
              "name": "List Tiers",
              "request": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/api/configuration/loyalty-tiers", "host": ["{{baseUrl}}"], "path": ["api","configuration","loyalty-tiers"] }
              }
            },
            {
              "name": "Create / Update Tier",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"id\": 1,\n  \"name\": \"Gold\",\n  \"pointsFrom\": 5000,\n  \"pointsTo\": 20000,\n  \"spendFrom\": 100000,\n  \"spendTo\": 250000,\n  \"rewardPercentage\": 10,\n  \"redeemValue\": 2,\n  \"benefits\": \"10% discount, Free delivery\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{baseUrl}}/api/configuration/loyalty-tiers", "host": ["{{baseUrl}}"], "path": ["api","configuration","loyalty-tiers"] },
                "description": "Omit `id` to create a new tier"
              }
            },
            {
              "name": "Delete Tier",
              "request": {
                "method": "DELETE",
                "url": {
                  "raw": "{{baseUrl}}/api/configuration/loyalty-tiers/:id",
                  "host": ["{{baseUrl}}"],
                  "path": ["api","configuration","loyalty-tiers",":id"],
                  "variable": [{ "key": "id", "value": "1" }]
