{
  "info": {
    "name": "LoyalArc API",
    "description": "Complete API reference for LoyalArc loyalty program platform.\n\nHow to use:\n1. Set the `baseUrl` variable to your Railway API URL (e.g. https://your-api.up.railway.app)\n2. Call POST {{baseUrl}}/api/auth/login to get a token\n3. The collection auto-saves the token — all other requests use it automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://your-api.up.railway.app", "type": "string" },
    { "key": "token",   "value": "",                                 "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('token', res.access_token);",
                  "  console.log('Token saved automatically');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        }
      ]
    },

    {
      "name": "2. Webhooks",
      "item": [
        {
          "name": "Post Transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "TXN-20260518-001", "description": "Optional — auto-derived from transaction_id if omitted" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction_id\": \"TXN-20260518-001\",\n  \"customer_mobile\": \"3001234567\",\n  \"customer_name\": \"Ahmed Khan\",\n  \"sale_amount\": 5500,\n  \"transaction_date\": \"2026-05-18T10:00:00.000Z\",\n  \"store\": \"Karachi Main\",\n  \"region\": \"South\",\n  \"receipt_no\": \"RCP-001\",\n  \"outlet\": \"Ground Floor\",\n  \"country_code\": \"92\",\n  \"items\": [\n    {\n      \"sku\": \"SKU-001\",\n      \"description\": \"Blue Denim Jeans\",\n      \"qty\": 2,\n      \"unit_price\": 2000,\n      \"total_price\": 4000\n    },\n    {\n      \"sku\": \"SKU-002\",\n      \"description\": \"Cotton T-Shirt\",\n      \"qty\": 1,\n      \"unit_price\": 1500,\n      \"total_price\": 1500\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/webhooks/transaction", "host": ["{{baseUrl}}"], "path": ["api","webhooks","transaction"] }
          }
        },
        {
          "name": "Upsert Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"RP-CUST-001\",\n  \"name\": \"Nadia Butt\",\n  \"mobile\": \"3091234567\",\n  \"email\": \"nadia@example.com\",\n  \"dob\": \"1986-06-20\",\n  \"gender\": \"Female\",\n  \"region\": \"South\",\n  \"store\": \"Karachi Clifton\",\n  \"country_code\": \"92\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/webhooks/customer", "host": ["{{baseUrl}}"], "path": ["api","webhooks","customer"] }
          }
        }
      ]
    },

    {
      "name": "3. Customers",
      "item": [
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/customers?page=1&pageSize=50",
              "host": ["{{baseUrl}}"],
              "path": ["api","customers"],
              "query": [
                { "key": "search",   "value": "",   "disabled": true, "description": "Search by name or mobile" },
                { "key": "tierId",   "value": "",   "disabled": true, "description": "Filter by tier ID" },
                { "key": "region",   "value": "",   "disabled": true },
                { "key": "store",    "value": "",   "disabled": true },
                { "key": "page",     "value": "1" },
                { "key": "pageSize", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Get Customer by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api","customers",":id"],
              "variable": [{ "key": "id", "value": "paste-customer-uuid-here" }]
            }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed Khan\",\n  \"email\": \"ahmed@example.com\",\n  \"dateOfBirth\": \"1990-01-15\",\n  \"gender\": \"Male\",\n  \"region\": \"North\",\n  \"store\": \"Lahore Main\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api","customers",":id"],
              "variable": [{ "key": "id", "value": "paste-customer-uuid-here" }]
            }
          }
        },
        {
          "name": "Get Transaction History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id/history?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api","customers",":id","history"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "pageSize", "value": "20" }
              ],
              "variable": [{ "key": "id", "value": "paste-customer-uuid-here" }]
            }
          }
        },
        {
          "name": "Get Points Ledger",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id/points-ledger?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api","customers",":id","points-ledger"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "pageSize", "value": "20" }
              ],
              "variable": [{ "key": "id", "value": "paste-customer-uuid-here" }]
            }
          }
        },
        {
          "name": "Award Bonus Points",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"points\": 500,\n  \"reason\": \"Birthday gift\",\n  \"awardedBy\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id/award-points",
              "host": ["{{baseUrl}}"],
              "path": ["api","customers",":id","award-points"],
              "variable": [{ "key": "id", "value": "paste-customer-uuid-here" }]
            }
          }
        },
        {
          "name": "Send WhatsApp Notification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"template_name\": \"points_earned_confirmation\",\n  \"message\": \"Dear Ahmed, your points have been credited.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id/notify",
              "host": ["{{baseUrl}}"],
              "path": ["api","customers",":id","notify"],
              "variable": [{ "key": "id", "value": "paste-customer-uuid-here" }]
            }
          }
        }
      ]
    },

